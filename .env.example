# Copy this file to .env. Docker Compose uses it both for `${...}`
# interpolation and as the environment passed to TailState.

# Container and host settings
TAILSTATE_IMAGE=ghcr.io/crypt0rr/tailstate:latest
TAILSTATE_BIND_ADDRESS=127.0.0.1
TAILSTATE_PORT=8080
TAILSTATE_CONFIG_FILE=./config.yaml

# Non-secret Tailscale identifiers
TAILSCALE_TAILNET=example.com
TAILSCALE_OAUTH_CLIENT_ID=k1234567890

# Non-secret Telegram destination identifier
TELEGRAM_CHAT_ID=-1001234567890

# Incoming webhook URLs usually embed a credential. Keeping one here is
# convenient for local Compose use, but means .env must be treated as secret.
MATTERMOST_WEBHOOK_URL=https://mattermost.example/hooks/replace-me

# These variables point to files containing secret values. The secret values
# themselves do not need to be placed in .env.
TAILSCALE_OAUTH_SECRET_FILE=./secrets/tailscale_oauth_secret
TAILSCALE_WEBHOOK_SECRET_FILE=./secrets/tailscale_webhook_secret
TELEGRAM_BOT_TOKEN_FILE=./secrets/telegram_bot_token
